ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AEAIEngin" "${PODS_CONFIGURATION_BUILD_DIR}/AEAIModule" "${PODS_CONFIGURATION_BUILD_DIR}/AEAINetworkModule" "${PODS_CONFIGURATION_BUILD_DIR}/AEFoundation" "${PODS_CONFIGURATION_BUILD_DIR}/AEModuleCenter" "${PODS_CONFIGURATION_BUILD_DIR}/AENetworkEngine"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AEAIEngin/AEAIEngin.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/AEAIModule/AEAIModule.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/AEAINetworkModule/AEAINetworkModule.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/AEFoundation/AEFoundation.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/AEModuleCenter/AEModuleCenter.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/AENetworkEngine/AENetworkEngine.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/../Frameworks' '@loader_path/Frameworks' "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}"
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_LDFLAGS = $(inherited) -framework "AEAIEngin" -framework "AEAIModule" -framework "AEAINetworkModule" -framework "AEFoundation" -framework "AEModuleCenter" -framework "AENetworkEngine" -framework "AppKit" -framework "Foundation"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
